<Window x:Class="AccesosLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AccesosLauncher"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Accesos" Width="800" Height="600"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Visibility="Hidden" ShowInTaskbar="False"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">
    <Window.Resources>
        <CollectionViewSource x:Key="GroupedItems" Source="{Binding Items}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="RelativeDirectory"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Visible"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" BorderBrush="#80FFFFFF">
        <DockPanel MouseLeftButtonDown="DockPanel_MouseLeftButtonDown">
            <TabControl x:Name="MainTabControl" SelectionChanged="MainTabControl_SelectionChanged" Margin="0,5,0,0">
                <TabControl.Resources>
                </TabControl.Resources>
                <TabItem Header="Accesos">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10">
                            <TextBlock Text="Tipo:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White"/>
                            <ComboBox x:Name="TipoCarpetaComboBox" Width="120"
                                      ItemsSource="{Binding Source={local:EnumValues {x:Type local:TipoCarpeta}}}"
                                      SelectedItem="{Binding SelectedTipoCarpeta}"
                                      VerticalAlignment="Center">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Setter Property="BorderBrush" Value="Gray"/>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                            <Button Content="Crear directorio en raiz" Click="CreateRootDirectoryButton_Click" Margin="10,0,5,0" Padding="5,2"/>
                            <Button Content="Actualizar" Click="RefreshButton_Click" Margin="5,0,10,0" Padding="5,2"/>
                            <TextBlock Text="Buscar:" VerticalAlignment="Center" Margin="10,0,8,0" Foreground="White"/>
                            <TextBox x:Name="SearchBox" Width="380"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center"
                                     Background="#30FFFFFF" Foreground="White" BorderBrush="Gray"
                                     KeyDown="SearchBox_KeyDown"/>
                            <TextBlock Text="{Binding ResultCountText}" Margin="12,0,0,0" VerticalAlignment="Center"
                                       Foreground="LightGray"/>
                        </StackPanel>

                        <ListView ItemsSource="{Binding Source={StaticResource GroupedItems}}" x:Name="ListViewItems"
                                  ScrollViewer.CanContentScroll="False"
                                  Background="Transparent" BorderBrush="Transparent"
                                  AllowDrop="True"
                                  Drop="ListView_Drop"
                                  DragEnter="ListView_DragEnter">
                            <ListView.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Margin="0,12,0,6" Foreground="White">
                                                <TextBlock.ContextMenu>
                                                    <ContextMenu Loaded="FolderContextMenu_Loaded">
                                                        <MenuItem Header="Renombrar" Click="RenameFolderMenuItem_Click"/>
                                                        <MenuItem Header="Abrir carpeta" Click="OpenFolderMenuItem_Click"/>
                                                        <MenuItem Header="Abrir todos los archivos de la carpeta" Click="OpenAllFilesMenuItem_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="Tipo">
                                                            <MenuItem Header="Personal" Tag="Personal"/>
                                                            <MenuItem Header="Laboral" Tag="Laboral"/>
                                                            <MenuItem Header="Ambos" Tag="Ambos"/>
                                                        </MenuItem>
                                                        <Separator/>
                                                        <MenuItem Header="Crear nueva carpeta" Click="CreateFolderMenuItem_Click"/>
                                                        <MenuItem Header="Eliminar carpeta" Click="DeleteFolderMenuItem_Click"/>
                                                    </ContextMenu>
                                                </TextBlock.ContextMenu>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                    <GroupStyle.Panel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel IsItemsHost="True"/>
                                        </ItemsPanelTemplate>
                                    </GroupStyle.Panel>
                                </GroupStyle>
                            </ListView.GroupStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="6" Padding="8"
                                            Tag="{Binding}"
                                            Click="ItemButton_Click"
                                            PreviewMouseLeftButtonDown="ItemButton_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="ItemButton_PreviewMouseMove"
                                            ToolTip="{Binding FullPath}"
                                            Width="160" Height="120"
                                            Background="Transparent" BorderBrush="Transparent">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Renombrar" Click="RenameMenuItem_Click"/>
                                                <MenuItem Header="Eliminar" Click="DeleteMenuItem_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image Source="{Binding Icon}" Width="48" Height="48"
                                                   SnapsToDevicePixels="True" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="140"
                                                       TextWrapping="Wrap" Margin="4,6,4,0" Foreground="White"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEmptyFolder}" Value="True">
                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                                <Setter Property="Opacity" Value="0.7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Proyectos">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,10,5">
                            <Button x:Name="btnCrearProyecto" Content="Nuevo Proyecto" Click="BtnCrearProyecto_Click" Margin="0,0,5,0" Padding="10,5"/>
                            <Button x:Name="btnEditarProyecto" Content="Editar" Click="BtnEditarProyecto_Click" Margin="5,0,5,0" Padding="10,5" IsEnabled="False"/>
                            <Button x:Name="btnEliminarProyecto" Content="Eliminar" Click="BtnEliminarProyecto_Click" Margin="5,0,5,0" Padding="10,5" IsEnabled="False"/>
                            <Button x:Name="btnActivarDesactivar" Content="Desactivar" Click="BtnActivarDesactivar_Click" Margin="5,0,5,0" Padding="10,5" IsEnabled="False"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,5">
                            <CheckBox x:Name="chkSoloActivos" Content="Solo activos" IsChecked="True" 
                                      Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"
                                      Checked="ChkSoloActivos_Changed" Unchecked="ChkSoloActivos_Changed"/>
                            <TextBox x:Name="txtBuscarProyecto" Width="380" 
                                     Text="{Binding BuscarProyectoText, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center" KeyDown="TxtBuscarProyecto_KeyDown"/>
                        </StackPanel>
                        <DataGrid Grid.Row="2" x:Name="dgProyectos" 
                                  ItemsSource="{Binding Proyectos}"
                                  SelectedItem="{Binding SelectedProyecto}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow"
                                  Margin="10,5" Sorting="DgProyectos_Sorting">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                                <DataGridTextColumn Header="Activo" Binding="{Binding ActivoIcono}" Width="90"/>
                                <DataGridTextColumn Header="Descripcion" Binding="{Binding DescripcionCortaTruncada}" Width="2*"/>
                                <DataGridTextColumn Header="Ultimo Acceso" Binding="{Binding FechaUltimoAcceso, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="Gray" DragCompleted="GridSplitterProyectos_DragCompleted"/>
                        <Grid Grid.Row="4" Margin="10,5,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="colProyectoDescripcion" Width="6*" MinWidth="200"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition x:Name="colProyectoAccesos" Width="5*" MinWidth="200"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,5,0">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="5">
                                        <TextBlock Text="Descripcion" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button x:Name="btnEditarDescripcion" Content="✏️" Click="BtnEditarDescripcion_Click" 
                                                Margin="10,0,0,0" Padding="5,2" IsEnabled="False" ToolTip="Editar descripcion"/>
                                        <Button x:Name="btnGuardarDescripcion" Content="✓" Click="BtnGuardarDescripcion_Click" 
                                                Margin="5,0,0,0" Padding="5,2" Visibility="Collapsed" ToolTip="Guardar"/>
                                        <Button x:Name="btnCancelarDescripcion" Content="✕" Click="BtnCancelarDescripcion_Click" 
                                                Margin="5,0,0,0" Padding="5,2" Visibility="Collapsed" ToolTip="Cancelar"/>
                                    </StackPanel>
                                    <RichTextBox x:Name="rtxtDescripcion" IsReadOnly="True" 
                                                 VerticalContentAlignment="Top" BorderThickness="0"
                                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                                 Margin="5"/>
                                </DockPanel>
                            </Border>
                            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Gray" DragCompleted="GridSplitterProyectos_DragCompleted"/>
                            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="5,0,0,0">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="5">
                                        <TextBlock Text="Accesos" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button x:Name="btnAgregarAcceso" Content="+" Click="BtnAgregarAcceso_Click" 
                                                Margin="10,0,0,0" Padding="5,2" IsEnabled="False" ToolTip="Agregar acceso"/>
                                    </StackPanel>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <WrapPanel x:Name="wrapPanelAccesos" AllowDrop="True" Drop="WrapPanelAccesos_Drop" DragEnter="WrapPanelAccesos_DragEnter" DragOver="WrapPanelAccesos_DragOver" PreviewMouseLeftButtonDown="WrapPanelAccesos_PreviewMouseLeftButtonDown" PreviewMouseMove="WrapPanelAccesos_PreviewMouseMove">
                                        </WrapPanel>
                                    </ScrollViewer>
                                    <TextBlock x:Name="emptyStateAccesos" Text="Este proyecto no tiene accesos. Usá el botón + para agregar." 
                                               Foreground="LightGray" FontStyle="Italic" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" Margin="10" Visibility="Collapsed"/>
                                </DockPanel>
                            </Border>
                        </Grid>
                        <Border x:Name="emptyStateProyectos" Grid.Row="2" Grid.RowSpan="3" 
                                Background="#EE000000" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="No tenes proyectos aun" Foreground="White" FontSize="18" 
                                           HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                <Button Content="Crear tu primer proyecto" Click="BtnCrearProyecto_Click" 
                                        Padding="15,8" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="toastPanel" Grid.Row="0" Grid.RowSpan="5" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="15" Padding="16,12" Background="#DD333333" CornerRadius="8"
                                Visibility="Collapsed" MinWidth="250" MaxWidth="400" IsHitTestVisible="False">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="toastIcon" Text="&#x2713;" Foreground="#4CAF50" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="toastMessage" Foreground="White" FontSize="14" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="Más Usados">
                    <DockPanel>
                        <Button Content="Limpiar" DockPanel.Dock="Bottom" HorizontalAlignment="Right" Margin="10" Padding="10,5" Click="ClearDatabase_Click"/>
                        <DataGrid ItemsSource="{Binding MostUsedItems}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="300"/>
                                <DataGridTextColumn Header="Último Uso" Binding="{Binding LastAccessTime, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}" Width="200"/>
                                <DataGridTextColumn Header="Usos" Binding="{Binding AccessCount}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Configuracion">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid ItemsSource="{Binding AppSettings}" AutoGenerateColumns="False" CanUserAddRows="False" Grid.Row="0" KeyboardNavigation.TabNavigation="None">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Setting" Binding="{Binding Key}" IsReadOnly="True" Width="*"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Minimizar" Click="MinimizeButton_Click" Margin="10" Padding="10,5"/>
                            <Button Content="Maximizar / Normal" Click="ToggleWindowState_Click" Margin="10" Padding="10,5"/>
                            <Button Content="Guardar Cambios" Click="SaveSettings_Click" HorizontalAlignment="Right" Margin="10" Padding="10,5"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
                <TabItem Header="Obtener icono">
                    <StackPanel Orientation="Horizontal" Margin="10" VerticalAlignment="Top">
                        <TextBlock Text="Url:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White"/>
                        <TextBox x:Name="IconUrlTextBox" Width="400" VerticalAlignment="Center" Background="#30FFFFFF" Foreground="White" BorderBrush="Gray"/>
                        <Button Content="Obtener" Click="GetIconButton_Click" Margin="10,0,0,0" Padding="5,2"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Acerca de">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="10">
                            <Label x:Name="VersionLabel" HorizontalAlignment="Center" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="Atajos de teclado" FontSize="20" FontWeight="Bold" Margin="0,10,0,0" Foreground="White" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <ScrollViewer>
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding KeyboardShortcuts}" Margin="10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#80FFFFFF" BorderThickness="0,0,0,1" Padding="5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Shortcut}" FontWeight="Bold" Foreground="LightBlue" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="White" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Image Source="/bannerV3.png" HorizontalAlignment="Center" Margin="10" Stretch="Uniform"/>
                                <TextBlock HorizontalAlignment="Center" Margin="10" Background="White">
                                    <Hyperlink NavigateUri="https://github.com/LicTony" RequestNavigate="Hyperlink_RequestNavigate">
                                        https://github.com/LicTony
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Border>
</Window>
