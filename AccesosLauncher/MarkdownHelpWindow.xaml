<Window x:Class="AccesosLauncher.MarkdownHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ayuda de Markdown"
        Width="620"
        Height="500"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="DarkCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1f6feb"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver}" Value="True">
                    <Setter Property="Background" Value="#21262d"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#0d1117"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#21262d"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1f6feb"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="Foreground" Value="#58a6ff"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
        </Style>
    </Window.Resources>
    <Grid Background="#0d1117">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Doble-click para insertar en el editor" 
                   Foreground="#8b949e" 
                   FontSize="12"
                   Margin="12,8,12,4"/>

        <DataGrid Grid.Row="1"
                  x:Name="dgHelp"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#30363d"
                  Background="#0d1117"
                  RowBackground="#0d1117"
                  BorderBrush="#30363d"
                  BorderThickness="1"
                  Margin="10,4,10,10"
                  FontFamily="Consolas"
                  FontSize="13"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CellStyle="{StaticResource DarkCellStyle}"
                  RowStyle="{StaticResource DarkRowStyle}"
                  ColumnHeaderStyle="{StaticResource DarkHeaderStyle}"
                  MouseDoubleClick="dgHelp_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sintaxis" Binding="{Binding Sintaxis}" Width="160"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                <DataGridTextColumn Header="Ejemplo" Binding="{Binding Ejemplo}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="Cerrar" Click="btnCerrar_Click" Width="100" Height="30" Margin="0,0,15,10" HorizontalAlignment="Right"/>
    </Grid>
</Window>
